# selfstream – Beispiel-Umgebungsvariablen
# Diese Datei nach ".env" kopieren und Werte eintragen:
#   cp .env.example .env
# docker-compose liest die .env automatisch ein (siehe docker-compose.yml).
# Alle Variablen sind optional – leer lassen aktiviert den Setup-Wizard beim ersten Start.

# Admin-Passwort für das Admin-Panel.
# Leer lassen -> Setup-Wizard beim ersten Start.
# Wenn gesetzt, kann das Passwort NICHT mehr über die UI geändert werden.
ADMIN_TOKEN=

# Öffentliche URL des Admin-Panels, z.B. http://192.168.1.69:8080
# Leer lassen -> wird im Setup-Wizard gesetzt.
BASE_URL=

# Öffentliche URL des IPTV-Proxys, z.B. https://iptv.deinedomain.de
# Wenn gesetzt, überschreibt die Proxy-URL aus der Datenbank.
# Alle M3U- und Stream-Links verwenden dann diese URL.
PROXY_URL=

# Pfad zur SQLite-Datenbank im Container. Normalerweise nicht ändern.
DB_PATH=/data/selfstream.db
